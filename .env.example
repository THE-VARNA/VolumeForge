# ─────────────────────────────────────────
# VolumeForge — Environment Variables
# Copy to .env.local and fill in values
# ─────────────────────────────────────────

# ── Database ─────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/volumeforge

# ── Torque Platform ───────────────────────
# Bearer token — from platform.torque.so → Account → API Settings
TORQUE_API_TOKEN=

# API key for event ingestion — used as x-api-key header when sending events to ingest.torque.so
# Create via: platform.torque.so → Project → API Keys → create_api_key
TORQUE_API_KEY=

# Active Torque project ID (set after project selection)
TORQUE_PROJECT_ID=

# Torque API base URL
TORQUE_BASE_URL=https://api.torque.so

# Torque event ingestion URL (confirmed from official docs)
TORQUE_INGEST_URL=https://ingest.torque.so/events

# ── Solana ────────────────────────────────
NEXT_PUBLIC_RPC_URL=https://api.mainnet-beta.solana.com

# ── App ───────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
